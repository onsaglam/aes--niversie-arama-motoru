# ─── ZORUNLU ─────────────────────────────────────────────────────────────────

# Anthropic API (claude.ai hesabının API versiyonu)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-BURAYA_YAZ

# Tavily AI — web arama motoru (LLM için optimize)
# https://app.tavily.com → "API Keys"
# Ücretsiz: 1.000 istek/ay
TAVILY_API_KEY=tvly-BURAYA_YAZ

# ─── ÖNERİLEN ────────────────────────────────────────────────────────────────

# ScraperAPI — anti-bot bypass (Cloudflare'li siteler için)
# https://dashboard.scraperapi.com → "API Key"
# Ücretsiz: 5.000 istek/ay
SCRAPER_API_KEY=BURAYA_YAZ

# ─── OPSİYONEL ───────────────────────────────────────────────────────────────

# Serper.dev — Google arama (Tavily yedeği)
# https://serper.dev/api-key
# Ücretsiz: 2.500 istek/ay
SERPER_API_KEY=BURAYA_YAZ

# Bright Data — Residential proxy (çok sert engellemeler için)
# https://brightdata.com → sadece gerçekten takılırsan gerek
BRIGHT_DATA_USERNAME=
BRIGHT_DATA_PASSWORD=
BRIGHT_DATA_HOST=brd.superproxy.io
BRIGHT_DATA_PORT=33335

# ─── AYARLAR ─────────────────────────────────────────────────────────────────

# Önbellek süresi (saat) — aynı URL bu süre içinde tekrar çekilmez
CACHE_TTL_HOURS=24

# Maksimum paralel istek sayısı (sunucu yükünü azaltmak için)
MAX_CONCURRENT_REQUESTS=3

# Debug modu — True yapınca Playwright görünür pencerede çalışır
HEADED_MODE=False
